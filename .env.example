# ==============================
# Polymarket Credentials
# ==============================
POLYMARKET_PRIVATE_KEY=your_polygon_wallet_private_key_here
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_api_secret
POLYMARKET_API_PASSPHRASE=your_polymarket_passphrase

# ==============================
# Polymarket Market
# ==============================
# BTC 5m 市場的 Token ID (從 Polymarket 網站獲取)
POLYMARKET_TOKEN_ID=your_token_id_here

# ==============================
# Trading Parameters
# ==============================
# 安全起見，默認 false，確認一切正常後改為 true
TRADING_ENABLED=false
POSITION_SIZE_USD=5
MAX_DAILY_LOSS_USD=100
ALPHA_THRESHOLD=0.05

# ==============================
# System
# ==============================
LOG_LEVEL=INFO
SAVE_RAW_DATA=true
